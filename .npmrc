@talchain:registry=https://npm.pkg.github.com
# NPM_PACKAGES_TOKEN: PAT with read:packages scope (required for cross-repo @talchain packages in CI)
# GITHUB_TOKEN fallback only works for packages in the same repo, not cross-org packages.
# See: https://docs.github.com/en/packages/working-with-a-github-packages-registry/working-with-the-npm-registry#authenticating-with-a-personal-access-token
//npm.pkg.github.com/:_authToken=${NPM_PACKAGES_TOKEN}
